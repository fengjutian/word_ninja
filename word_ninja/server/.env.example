# Word Ninja Server 环境变量配置
# 复制此文件为 .env 并修改相应值

# 服务器端口
PORT=8080

# PostgreSQL 数据库连接
DATABASE_URL=postgres://postgres:postgres@localhost:5432/word_ninja?sslmode=disable

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# JWT 密钥（生产环境必须修改！）
JWT_SECRET=change-me-to-a-random-string

# OpenAI API 配置
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
